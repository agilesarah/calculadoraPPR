<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora de Rendimentos</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f9;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }
        .calculadora {
            background-color: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            width: 100%;
            max-width: 400px;
        }
        .calculadora h2 {
            text-align: center;
            color: #333;
            margin-top: 0;
        }
        .campo {
            margin-bottom: 15px;
        }
        label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #555;
        }
        input {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 5px;
            box-sizing: border-box;
            font-size: 16px;
        }
        button {
            width: 100%;
            padding: 12px;
            background-color: #28a745;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        button:hover {
            background-color: #218838;
        }
        .resultado {
            margin-top: 20px;
            padding: 15px;
            background-color: #e9ecef;
            border-radius: 5px;
            text-align: center;
            font-size: 1.2em;
            font-weight: bold;
            color: #333;
            display: none; /* Fica oculto até calcular */
        }
    </style>
</head>
<body>

<div class="calculadora">
    <h2>Cálculo de Rendimentos</h2>
    
    <div class="campo">
        <label for="rendimentos">Total de Rendimentos (R$)</label>
        <input type="number" id="rendimentos" placeholder="Ex: 120000" step="0.01">
    </div>
    
    <div class="campo">
        <label for="nota">Nota do Plano de Ação</label>
        <input type="number" id="nota" placeholder="Ex: 91.10" step="0.01">
    </div>
    
    <div class="campo">
        <label for="meses">Meses Trabalhados</label>
        <input type="number" id="meses" placeholder="Ex: 12" min="1" max="12">
    </div>
    
    <button onclick="calcular()">Calcular Resultado</button>

    <div id="resultado" class="resultado"></div>
</div>

<script>
    function calcular() {
        // 1. Pega os valores inseridos pelo usuário
        const rendimentos = parseFloat(document.getElementById('rendimentos').value);
        const nota = parseFloat(document.getElementById('nota').value);
        const meses = parseFloat(document.getElementById('meses').value);

        // 2. Verifica se algum campo ficou em branco
        if (isNaN(rendimentos) || isNaN(nota) || isNaN(meses)) {
            const divResultado = document.getElementById('resultado');
            divResultado.style.display = 'block';
            divResultado.style.color = 'red';
            divResultado.innerText = "Por favor, preencha todos os campos.";
            return;
        }

        // 3. Transforma a nota em percentual (ex: 91.10 vira 0.9110)
        const percentualPlano = nota / 100;

        // 4. Aplica a fórmula solicitada
        // (TOTAL/12) * 1.0 * PERCENTUAL * (MESES/12)
        const valorFinal = (rendimentos / 12) * 1.0 * percentualPlano * (meses / 12);

        // 5. Exibe o resultado formatado em Reais (BRL)
        const divResultado = document.getElementById('resultado');
        divResultado.style.display = 'block';
        divResultado.style.color = '#333';
        divResultado.innerText = "Resultado: " + valorFinal.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });
    }
</script>

</body>
</html>
